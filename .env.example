# Telegram — push alerts (main.py run)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# TELEGRAM_EXTRA_IDS=   # comma-separated extra chat IDs to receive push alerts

# Telegram — interactive bot (bot.py)
# Create a separate bot via @BotFather, or leave blank to reuse TELEGRAM_BOT_TOKEN
TELEGRAM_INTERACTIVE_BOT_TOKEN=

# Google Sheets (optional)
GOOGLE_SHEETS_ID=
GOOGLE_SHEETS_CREDENTIALS_JSON=credentials.json

# LinkedIn (session cookie from browser devtools -> Application -> Cookies -> li_at)
LINKEDIN_COOKIE=

# Instagram session (sessionid cookie)
INSTAGRAM_SESSION=

# Playwright
HEADLESS=true

# Scraping delays (seconds)
REQUEST_DELAY=2
REQUEST_TIMEOUT=30
MAX_RETRIES=3

# Confidence thresholds
CONFIDENCE_HIGH_THRESHOLD=0.75
CONFIDENCE_MEDIUM_THRESHOLD=0.4

# Data retention (days)
SNAPSHOT_RETENTION_DAYS=90

# Logging
LOG_LEVEL=INFO
